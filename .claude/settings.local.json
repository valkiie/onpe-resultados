      "Bash(curl -s \"https://resultadoelectoral.onpe.gob.pe/presentacion-backend/actas/buscar/mesa?codigoMesa=900234\" -H \"Accept: application/json\" -H \"X-Requested-With: XMLHttpRequest\")",
      "Bash(curl -s \"https://resultadoelectoral.onpe.gob.pe/main-QATEOCH2.js\")",
