      "Bash(curl -s -A \"Mozilla/5.0 \\(Windows NT 10.0; Win64; x64\\) AppleWebKit/537.36\" \"https://resultadoelectoral.onpe.gob.pe/main-QATEOCH2.js\" -o /tmp/main_js.js)",
      "Bash(grep -oE '\"https?://[^\"]{5,150}\"' /tmp/main_js.js)",
